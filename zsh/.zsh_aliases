alias gaa="git add ."
alias gc="git commit"
alias gcm="git commit -m"
alias gca="git commit --amend"
alias gp="git push"
alias gpl="git pull"
alias gf="git fetch"
alias gco="git checkout"
alias gcb="git checkout -b"
alias gb="git branch"
alias gbd="git branch -d"
alias gl="git log --oneline --graph --decorate --all"
alias gd="git diff"
alias grb="git rebase"
alias gst="git stash"
alias gstp="git stash pop"
alias gundo="git reset HEAD~1 --mixed"
alias lg="lazygit"

# git repos
alias unitex="curl -s https://dl.intonerzero.com/github/university-latex-template/install.sh | bash"

# npm
alias ni="npm install"
alias nid="npm install --save-dev"
alias nr="npm run"
alias nrb="npm run build"
alias nrd="npm run dev"
alias nrt="npm run test"
alias nes="npx expo start"

# python
alias py="python3"
alias pip="pip3"
alias venv="python3 -m venv .venv"
alias activate="source .venv/bin/activate"

# go
alias gor="go run ."
alias gob="go build ."
alias got="go test ./..."
alias gotv="go test -v ./..."

# docker 
alias dk="docker"
alias dkc="docker compose"
alias dkcu="docker compose up"
alias dkcd="docker compose down"
alias dkps="docker ps"

# system
alias reload="source ~/.zshrc"
alias zshrc="nvim ~/.zshrc"
alias hosts="sudo nvim /etc/hosts"
alias ip="ipconfig getifaddr en0"
alias pubip="curl -s https://ipecho.net/plain"
alias flushdns="sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder"

# neovim
alias vim="nvim"
alias vi="nvim"

# tmux
alias t="tmux"
alias ta="tmux attach"
alias tls="tmux ls"
alias tn="tmux new-session -s"
alias tk="tmux kill-session -t"
alias tka="tmux kill-server"

# misc
alias btop="btop"
alias jq="jq --indent 2"
alias weather="curl wttr.in"
alias speedtest="curl -s https://raw.githubusercontent.com/sivel/speedtest-cli/master/speedtest.py | python3 -"
alias c="clear"

# macOS specific
alias o="open"                                
alias oh="open ."
alias cleanup="\find . -type f -name '*.DS_Store' -delete"
alias ports="lsof -iTCP -sTCP:LISTEN -n -P"   
alias path='echo -e ${PATH//:/\\n}'     
alias please="sudo \$(fc -ln -1)"      
alias battery="ioreg -l| grep -e "CurrentCapacity" -e "MaxCapacity" -e "CycleCount""

# functions
# helper: open a URL in firefox detached from the terminal
_ff_open() {
  firefox -new-tab "$1" >/dev/null 2>&1 &!
}

# open git repo in firefox
gitweb() {
  local url
  url=$(git config --get remote.origin.url) || {
    echo "gitweb: not a git repo (or no 'origin' remote)" >&2
    return 1
  }
  url=${url/git@github.com:/https://github.com/}
  url=${url%.git}
  _ff_open "$url"
}

# open the current git repo's PR/issues page
gitprs() {
  local url
  url=$(git config --get remote.origin.url) || {
    echo "gitprs: not a git repo" >&2
    return 1
  }
  url=${url/git@github.com:/https://github.com/}
  url=${url%.git}
  _ff_open "$url/pulls"
}

# quick web search from the terminal
ffs() {
  if [[ $# -eq 0 ]]; then
    echo "usage: ffs <search terms>" >&2
    return 1
  fi
  local IFS='+'
  _ff_open "https://duckduckgo.com/?q=$*"
}

# open the current directory in firefox
ff() {
  local target="${1:-.}"
  _ff_open "file://$(realpath "$target")"
}

# open localhost on a given port
localhost() {
  _ff_open "http://localhost:${1:-3000}"
}
