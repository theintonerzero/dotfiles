[user]
    name = Jesse Darkovski 
    email = j.darkovski@gmail.com

[core]
    pager = delta
    editor = nvim

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[pull]
    rebase = false

[push]
    autoSetupRemote = true
